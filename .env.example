# NUNCA commite o arquivo .env real. Copie este template para .env e preencha.

# Banco de dados
DATABASE_URL=postgres://trader:trader_secret@localhost:5433/trader_db

# PostgreSQL para docker-compose (não usado diretamente pela aplicação)
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_secret
POSTGRES_DB=trader_db
POSTGRES_PORT=5433

# Modo de operação
TRADER_MODE=paper
TRADER_PAPER_WARNING=true

# Broker (IBKR TWS API / IB Gateway)
TRADER__IBKR__HOST=127.0.0.1
TRADER__IBKR__PORT=7497
TRADER__IBKR__CLIENT_ID=1
TRADER__IBKR__PAPER=true
TRADER__IBKR__ACCOUNT_ID=DU1234567

# Client Portal API (alternativa; não usada com TWS API)
IBKR_ACCOUNT_ID=DU1234567
IBKR_PAPER=true
IBKR_API_URL=https://localhost:5000/v1/api
IBKR_CLIENT_ID=seu_client_id

# TWS API (alternativa)
IBKR_TWS_HOST=127.0.0.1
IBKR_TWS_PORT=7497
IBKR_TWS_CLIENT_ID=1

# Estratégia ativa
TRADER_STRATEGY_ID=pullback-trend-v1
TRADER_STRATEGY_CONFIG_PATH=./config/strategies/pullback-trend-v1.toml

# Risco
TRADER_RISK_PROFILE=conservative

# Logging
RUST_LOG=info
RUST_LOG_FORMAT=pretty
